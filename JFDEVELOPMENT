    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700;800;900&display=swap" rel="stylesheet">
    <style>
      :root {
        --obsidian: #121212;
        --bone: #F5F5F5;
        --orange: #FF4F00;
        --cement: #4A4A4A;
        --font: 'Inter', -apple-system, BlinkMacSystemFont, 'Segoe UI', sans-serif;
      }
      * { margin: 0; padding: 0; box-sizing: border-box; }
      html { scroll-behavior: smooth; }
      body {
        font-family: var(--font);
        background: var(--obsidian);
        color: var(--bone);
        line-height: 1.6;
        -webkit-font-smoothing: antialiased;
        overflow-x: hidden;
      }
      #root { display: none; }
      ::-webkit-scrollbar { width: 6px; }
      ::-webkit-scrollbar-track { background: var(--obsidian); }
      ::-webkit-scrollbar-thumb { background: var(--cement); }
      ::-webkit-scrollbar-thumb:hover { background: var(--orange); }
      a:focus-visible, button:focus-visible, input:focus-visible, textarea:focus-visible {
        outline: 3px solid var(--orange);
        outline-offset: 2px;
      }
      img { max-width: 100%; display: block; }
      section { position: relative; }
      .container { max-width: 1280px; margin: 0 auto; padding: 0 24px; }
      @media (min-width: 1024px) { .container { padding: 0 48px; } }
      .section-label { display: flex; align-items: center; gap: 16px; margin-bottom: 80px; }
      .section-label .line { width: 48px; height: 1px; background: var(--orange); }
      .section-label span { color: var(--orange); font-size: 12px; font-weight: 700; letter-spacing: 0.3em; text-transform: uppercase; }

      /* NAVBAR */
      .navbar { position: fixed; top: 0; left: 0; right: 0; z-index: 100; height: 80px; display: flex; align-items: center; transition: all 0.5s ease; }
      .navbar.scrolled { background: rgba(18,18,18,0.95); backdrop-filter: blur(12px); border-bottom: 1px solid rgba(74,74,74,0.3); }
      .navbar .container { display: flex; align-items: center; justify-content: space-between; width: 100%; }
      .logo { display: flex; align-items: center; gap: 12px; text-decoration: none; }
      .logo .jf { color: var(--orange); font-weight: 900; font-size: 20px; letter-spacing: -0.02em; }
      .logo .dev { color: var(--bone); font-weight: 700; font-size: 12px; letter-spacing: 0.2em; text-transform: uppercase; }
      @media (max-width: 640px) { .logo .dev { display: none; } }
      .nav-links { display: none; align-items: center; gap: 40px; }
      @media (min-width: 1024px) { .nav-links { display: flex; } }
      .nav-links a { color: rgba(245,245,245,0.7); text-decoration: none; font-size: 12px; font-weight: 600; letter-spacing: 0.15em; text-transform: uppercase; transition: color 0.3s; padding: 8px 4px; }
      .nav-links a:hover { color: var(--orange); }
      .btn-cta { display: none; border: 1px solid var(--orange); color: var(--orange); text-decoration: none; font-size: 12px; font-weight: 700; letter-spacing: 0.15em; text-transform: uppercase; padding: 12px 24px; transition: all 0.3s; align-items: center; min-height: 48px; background: transparent; cursor: pointer; }
      @media (min-width: 1024px) { .btn-cta { display: inline-flex; } }
      .btn-cta:hover { background: var(--orange); color: #fff; }
      .mobile-toggle { display: flex; background: none; border: none; color: var(--bone); cursor: pointer; padding: 8px; min-width: 48px; min-height: 48px; align-items: center; justify-content: center; }
      @media (min-width: 1024px) { .mobile-toggle { display: none; } }
      .mobile-menu { display: none; flex-direction: column; gap: 24px; padding: 32px 24px; background: rgba(18,18,18,0.98); backdrop-filter: blur(12px); border-top: 1px solid rgba(74,74,74,0.3); }
      .mobile-menu.open { display: flex; }
      .mobile-menu a { color: rgba(245,245,245,0.8); text-decoration: none; font-size: 14px; font-weight: 600; letter-spacing: 0.15em; text-transform: uppercase; min-height: 48px; display: flex; align-items: center; }
      .mobile-menu .btn-cta-mobile { display: flex; border: 1px solid var(--orange); color: var(--orange); font-size: 14px; font-weight: 700; letter-spacing: 0.15em; text-transform: uppercase; padding: 16px; justify-content: center; min-height: 48px; text-decoration: none; }

      /* HERO */
      .hero { height: 100vh; min-height: 600px; overflow: hidden; display: flex; align-items: center; justify-content: center; text-align: center; }
      .hero-bg { position: absolute; inset: 0; }
      .hero-bg img { width: 100%; height: 100%; object-fit: cover; }
      .hero-bg::after { content: ''; position: absolute; inset: 0; background: rgba(18,18,18,0.7); }
      .hero-grid { position: absolute; inset: 0; opacity: 0.03; pointer-events: none; background-image: linear-gradient(rgba(245,245,245,1) 1px, transparent 1px), linear-gradient(90deg, rgba(245,245,245,1) 1px, transparent 1px); background-size: 60px 60px; }
      .hero-content { position: relative; z-index: 2; padding: 0 24px; max-width: 1152px; }
      .hero-tag { color: var(--orange); font-size: 11px; font-weight: 700; letter-spacing: 0.3em; text-transform: uppercase; margin-bottom: 32px; opacity: 0; animation: fadeUp 0.8s 0.2s forwards; }
      @media (min-width: 640px) { .hero-tag { font-size: 14px; } }
      .hero h1 { color: var(--bone); font-weight: 900; line-height: 1; letter-spacing: -0.02em; font-size: 3rem; margin-bottom: 32px; opacity: 0; animation: fadeUp 1s 0.4s forwards; }
      @media (min-width: 640px) { .hero h1 { font-size: 4.5rem; } }
      @media (min-width: 768px) { .hero h1 { font-size: 6rem; } }
      @media (min-width: 1024px) { .hero h1 { font-size: 7.5rem; } }
      @media (min-width: 1280px) { .hero h1 { font-size: 8rem; } }
      .hero h1 .accent { color: var(--orange); }
      .hero-sub { color: rgba(245,245,245,0.6); font-size: 1.0625rem; max-width: 640px; margin: 0 auto 48px; line-height: 1.8; opacity: 0; animation: fadeUp 0.8s 0.8s forwards; }
      @media (min-width: 640px) { .hero-sub { font-size: 1.125rem; } }
      .hero-actions { display: flex; flex-direction: column; gap: 16px; align-items: center; justify-content: center; opacity: 0; animation: fadeUp 0.8s 1s forwards; }
      @media (min-width: 640px) { .hero-actions { flex-direction: row; } }
      .btn-ghost { border: 2px solid var(--orange); color: var(--orange); text-decoration: none; font-weight: 700; font-size: 14px; letter-spacing: 0.15em; text-transform: uppercase; padding: 16px 40px; transition: all 0.3s; min-height: 48px; display: inline-flex; align-items: center; }
      .btn-ghost:hover { background: var(--orange); color: #fff; }
      .btn-text { color: rgba(245,245,245,0.5); text-decoration: none; font-weight: 600; font-size: 14px; letter-spacing: 0.15em; text-transform: uppercase; padding: 16px 40px; transition: color 0.3s; min-height: 48px; display: inline-flex; align-items: center; }
      .btn-text:hover { color: var(--bone); }
      .scroll-indicator { position: absolute; bottom: 40px; left: 50%; transform: translateX(-50%); z-index: 2; }
      .scroll-line { width: 1px; height: 64px; background: linear-gradient(to bottom, var(--orange), transparent); animation: scrollBounce 2s infinite; }
      @keyframes scrollBounce { 0%,100% { transform: translateY(0); } 50% { transform: translateY(10px); } }
      @keyframes fadeUp { from { opacity: 0; transform: translateY(30px); } to { opacity: 1; transform: translateY(0); } }

      /* ABOUT */
      .about { padding: 128px 0; border-top: 1px solid rgba(74,74,74,0.3); }
      @media (min-width: 1024px) { .about { padding: 176px 0; } }
      .about-grid { display: grid; gap: 64px; }
      @media (min-width: 1024px) { .about-grid { grid-template-columns: 1fr 1fr; gap: 96px; align-items: center; } }
      .about h2 { color: var(--bone); font-weight: 900; font-size: 2.25rem; line-height: 1.1; margin-bottom: 32px; }
      @media (min-width: 640px) { .about h2 { font-size: 3rem; } }
      @media (min-width: 1024px) { .about h2 { font-size: 3.75rem; } }
      .about h2 .accent { color: var(--orange); }
      .about .lead { color: rgba(245,245,245,0.6); font-size: 1.125rem; line-height: 1.8; margin-bottom: 48px; }
      .badges { display: grid; grid-template-columns: repeat(3, 1fr); gap: 16px; }
      .badge { border: 1px solid rgba(74,74,74,0.3); padding: 20px; transition: border-color 0.3s; }
      .badge:hover { border-color: rgba(255,79,0,0.5); }
      .badge .icon { color: var(--orange); margin-bottom: 12px; }
      .badge .value { color: var(--orange); font-weight: 900; font-size: 1.5rem; margin-bottom: 4px; }
      .badge .label { color: rgba(245,245,245,0.5); font-size: 10px; font-weight: 600; letter-spacing: 0.05em; text-transform: uppercase; }
      .about-img-wrap { position: relative; }
      .about-img-wrap img { width: 100%; height: 500px; object-fit: cover; }
      @media (min-width: 1024px) { .about-img-wrap img { height: 600px; } }
      .about-img-corner { position: absolute; bottom: -12px; right: -12px; width: 96px; height: 96px; border-bottom: 2px solid var(--orange); border-right: 2px solid var(--orange); }

      /* PROCESS */
      .process { padding: 128px 0; border-top: 1px solid rgba(74,74,74,0.3); }
      @media (min-width: 1024px) { .process { padding: 176px 0; } }
      .process h2 { color: var(--bone); font-weight: 900; font-size: 2.25rem; line-height: 1.1; margin-bottom: 24px; }
      @media (min-width: 640px) { .process h2 { font-size: 3rem; } }
      @media (min-width: 1024px) { .process h2 { font-size: 3.75rem; } }
      .process h2 .accent { color: var(--orange); }
      .process .lead { color: rgba(245,245,245,0.5); font-size: 1.125rem; line-height: 1.7; max-width: 768px; margin-bottom: 80px; }
      .steps { display: grid; gap: 0; }
      @media (min-width: 768px) { .steps { grid-template-columns: repeat(3, 1fr); } }
      .step { position: relative; padding: 32px; border: 1px solid rgba(74,74,74,0.2); transition: all 0.5s; overflow: hidden; }
      @media (min-width: 768px) { .step:not(:last-child) { border-right: none; } }
      @media (min-width: 1024px) { .step { padding: 48px; } }
      .step:hover { background: rgba(74,74,74,0.1); }
      .step-num { position: absolute; top: 16px; right: 24px; color: var(--orange); font-weight: 900; font-size: 4.5rem; opacity: 0.2; transition: opacity 0.5s; }
      @media (min-width: 1024px) { .step-num { font-size: 5rem; } }
      .step:hover .step-num { opacity: 0.4; }
      .step-content { position: relative; z-index: 1; }
      .step .icon { color: var(--orange); margin-bottom: 24px; }
      .step h3 { color: var(--bone); font-weight: 700; font-size: 1.125rem; letter-spacing: 0.1em; text-transform: uppercase; margin-bottom: 16px; }
      .step p { color: rgba(245,245,245,0.5); font-size: 1rem; line-height: 1.8; }
      .step-accent { position: absolute; bottom: 0; left: 0; height: 2px; width: 0; background: var(--orange); transition: width 0.7s; }
      .step:hover .step-accent { width: 100%; }

      /* SERVICES */
      .services { padding: 128px 0; background: var(--bone); color: var(--obsidian); }
      @media (min-width: 1024px) { .services { padding: 176px 0; } }
      .services h2 { color: var(--obsidian); font-weight: 900; font-size: 2.25rem; line-height: 1.1; margin-bottom: 24px; }
      @media (min-width: 640px) { .services h2 { font-size: 3rem; } }
      @media (min-width: 1024px) { .services h2 { font-size: 3.75rem; } }
      .services h2 .accent { color: var(--orange); }
      .services .lead { color: var(--cement); font-size: 1.125rem; line-height: 1.7; max-width: 768px; margin-bottom: 80px; }
      .services-grid { display: grid; gap: 32px; }
      @media (min-width: 768px) { .services-grid { grid-template-columns: repeat(3, 1fr); } }
      .service-card { background: #fff; border: 1px solid rgba(18,18,18,0.1); padding: 40px; transition: all 0.5s; position: relative; overflow: hidden; }
      @media (min-width: 1024px) { .service-card { padding: 48px; } }
      .service-card:hover { border-color: rgba(255,79,0,0.5); }
      .service-card .top-line { position: absolute; top: 0; left: 0; width: 100%; height: 2px; background: var(--orange); transform: scaleX(0); transform-origin: left; transition: transform 0.5s; }
      .service-card:hover .top-line { transform: scaleX(1); }
      .service-card .icon { color: var(--orange); margin-bottom: 24px; }
      .service-card h3 { color: var(--obsidian); font-weight: 700; font-size: 1.25rem; letter-spacing: 0.1em; text-transform: uppercase; margin-bottom: 16px; }
      .service-card p { color: var(--cement); font-size: 1rem; line-height: 1.8; }

      /* GALLERY */
      .gallery { padding: 128px 0; border-top: 1px solid rgba(74,74,74,0.3); }
      @media (min-width: 1024px) { .gallery { padding: 176px 0; } }
      .gallery-header { display: flex; flex-direction: column; gap: 24px; margin-bottom: 64px; }
      @media (min-width: 640px) { .gallery-header { flex-direction: row; align-items: flex-end; justify-content: space-between; } }
      .gallery h2 { color: var(--bone); font-weight: 900; font-size: 2.25rem; line-height: 1.1; }
      @media (min-width: 640px) { .gallery h2 { font-size: 3rem; } }
      @media (min-width: 1024px) { .gallery h2 { font-size: 3.75rem; } }
      .gallery h2 .accent { color: var(--orange); }
      .gallery-nav { display: flex; gap: 12px; }
      .gallery-nav button { width: 48px; height: 48px; border: 1px solid rgba(74,74,74,0.4); color: rgba(245,245,245,0.6); background: transparent; cursor: pointer; display: flex; align-items: center; justify-content: center; transition: all 0.3s; }
      .gallery-nav button:hover { border-color: var(--orange); color: var(--orange); }
      .gallery-scroll { display: flex; gap: 24px; overflow-x: auto; padding: 0 24px 16px; scrollbar-width: thin; scrollbar-color: var(--orange) var(--obsidian); }
      @media (min-width: 1024px) { .gallery-scroll { padding: 0 48px 16px; } }
      .gallery-scroll::-webkit-scrollbar { height: 4px; }
      .gallery-scroll::-webkit-scrollbar-track { background: var(--obsidian); }
      .gallery-scroll::-webkit-scrollbar-thumb { background: var(--orange); }
      .gallery-item { flex-shrink: 0; width: 300px; }
      @media (min-width: 640px) { .gallery-item { width: 350px; } }
      @media (min-width: 1024px) { .gallery-item { width: 400px; } }
      .gallery-img-wrap { position: relative; overflow: hidden; aspect-ratio: 3/4; }
      .gallery-img-wrap img { width: 100%; height: 100%; object-fit: cover; transition: transform 0.7s; }
      .gallery-item:hover .gallery-img-wrap img { transform: scale(1.1); }
      .gallery-overlay { position: absolute; inset: 0; background: rgba(18,18,18,0); transition: background 0.5s; display: flex; flex-direction: column; justify-content: flex-end; padding: 24px; opacity: 0; }
      .gallery-item:hover .gallery-overlay { background: rgba(18,18,18,0.6); opacity: 1; }
      .gallery-overlay .loc { color: var(--orange); font-size: 12px; font-weight: 700; letter-spacing: 0.2em; text-transform: uppercase; margin-bottom: 8px; }
      .gallery-overlay .params { color: var(--bone); font-size: 14px; }
      .gallery-info { margin-top: 16px; }
      .gallery-info h3 { color: var(--bone); font-weight: 700; font-size: 14px; letter-spacing: 0.1em; text-transform: uppercase; }
      .gallery-info .loc { color: var(--cement); font-size: 12px; letter-spacing: 0.1em; margin-top: 4px; }

      /* WHY US */
      .why { padding: 128px 0; border-top: 1px solid rgba(74,74,74,0.3); }
      @media (min-width: 1024px) { .why { padding: 176px 0; } }
      .why h2 { color: var(--bone); font-weight: 900; font-size: 2.25rem; line-height: 1.1; margin-bottom: 24px; max-width: 1024px; }
      @media (min-width: 640px) { .why h2 { font-size: 3rem; } }
      @media (min-width: 1024px) { .why h2 { font-size: 3.75rem; } }
      .why h2 .accent { color: var(--orange); }
      .why .lead { color: rgba(245,245,245,0.5); font-size: 1.125rem; line-height: 1.7; max-width: 768px; margin-bottom: 80px; }
      .stats { display: grid; gap: 0; }
      @media (min-width: 768px) { .stats { grid-template-columns: repeat(3, 1fr); } }
      .stat { border: 1px solid rgba(74,74,74,0.2); padding: 40px; text-align: center; transition: all 0.5s; position: relative; overflow: hidden; }
      @media (min-width: 1024px) { .stat { padding: 56px; } }
      @media (min-width: 768px) { .stat:not(:last-child) { border-right: none; } }
      .stat:hover { background: rgba(74,74,74,0.1); }
      .stat .number { color: var(--orange); font-weight: 900; font-size: 3.75rem; display: block; margin-bottom: 16px; }
      @media (min-width: 1024px) { .stat .number { font-size: 4.5rem; } }
      .stat h3 { color: var(--bone); font-weight: 700; font-size: 14px; letter-spacing: 0.15em; text-transform: uppercase; margin-bottom: 12px; }
      .stat p { color: rgba(245,245,245,0.4); font-size: 14px; line-height: 1.7; }
      .stat-accent { position: absolute; bottom: 0; left: 0; height: 2px; width: 0; background: var(--orange); transition: width 0.7s; }
      .stat:hover .stat-accent { width: 100%; }

      /* CONTACT */
      .contact { padding: 128px 0; background: var(--bone); color: var(--obsidian); }
      @media (min-width: 1024px) { .contact { padding: 176px 0; } }
      .contact h2 { color: var(--obsidian); font-weight: 900; font-size: 2.25rem; line-height: 1.1; margin-bottom: 80px; }
      @media (min-width: 640px) { .contact h2 { font-size: 3rem; } }
      @media (min-width: 1024px) { .contact h2 { font-size: 3.75rem; } }
      .contact h2 .accent { color: var(--orange); }
      .contact-grid { display: grid; gap: 64px; }
      @media (min-width: 1024px) { .contact-grid { grid-template-columns: 1fr 1fr; gap: 96px; } }
      .contact-info-list { display: flex; flex-direction: column; gap: 32px; margin-bottom: 48px; }
      .contact-info-item { display: flex; gap: 20px; align-items: flex-start; text-decoration: none; min-height: 48px; }
      .contact-info-item .icon-box { width: 48px; height: 48px; border: 1px solid rgba(18,18,18,0.2); flex-shrink: 0; display: flex; align-items: center; justify-content: center; transition: all 0.3s; }
      .contact-info-item:hover .icon-box { border-color: var(--orange); background: rgba(255,79,0,0.05); }
      .contact-info-item .icon-box .icon { color: var(--orange); }
      .contact-info-item .label { color: var(--cement); font-size: 11px; font-weight: 700; letter-spacing: 0.15em; text-transform: uppercase; margin-bottom: 4px; }
      .contact-info-item .value { color: var(--obsidian); font-weight: 600; font-size: 1.125rem; transition: color 0.3s; }
      .contact-info-item:hover .value { color: var(--orange); }
      .map-wrap { border: 1px solid rgba(18,18,18,0.1); overflow: hidden; }
      .map-wrap iframe { width: 100%; height: 256px; filter: grayscale(1) contrast(1.25); border: 0; }
      .contact-form { display: flex; flex-direction: column; gap: 24px; }
      .form-group label { color: var(--cement); font-size: 11px; font-weight: 700; letter-spacing: 0.15em; text-transform: uppercase; margin-bottom: 8px; display: block; }
      .form-group input, .form-group textarea { width: 100%; background: transparent; border: none; border-bottom: 2px solid rgba(18,18,18,0.2); color: var(--obsidian); font-size: 1.125rem; padding: 12px 0; outline: none; transition: border-color 0.3s; font-family: var(--font); resize: none; min-height: 48px; }
      .form-group input:focus, .form-group textarea:focus { border-bottom-color: var(--orange); }
      .form-group textarea { min-height: 120px; }
      .btn-submit { background: var(--orange); color: #fff; border: none; font-weight: 700; font-size: 14px; letter-spacing: 0.15em; text-transform: uppercase; padding: 16px 40px; cursor: pointer; transition: all 0.3s; min-height: 48px; margin-top: 16px; font-family: var(--font); }
      .btn-submit:hover { background: rgba(255,79,0,0.9); }
      .btn-submit:disabled { opacity: 0.5; cursor: not-allowed; }
      .form-success { text-align: center; padding: 48px 0; }
      .form-success .check-box { width: 64px; height: 64px; border: 2px solid var(--orange); margin: 0 auto 24px; display: flex; align-items: center; justify-content: center; }
      .form-success .check-box .icon { color: var(--orange); }
      .form-success h3 { color: var(--obsidian); font-weight: 700; font-size: 1.5rem; margin-bottom: 12px; }
      .form-success p { color: var(--cement); }
      .form-success .again { color: var(--orange); font-weight: 600; font-size: 14px; letter-spacing: 0.1em; margin-top: 24px; background: none; border: none; cursor: pointer; font-family: var(--font); min-height: 48px; }
      .form-success .again:hover { text-decoration: underline; }

      /* FOOTER */
      .footer { background: var(--obsidian); border-top: 1px solid rgba(74,74,74,0.2); color: var(--bone); }
      .footer-inner { max-width: 1280px; margin: 0 auto; padding: 80px 24px; }
      @media (min-width: 1024px) { .footer-inner { padding: 80px 48px; } }
      .footer-grid { display: grid; gap: 48px; }
      @media (min-width: 768px) { .footer-grid { grid-template-columns: repeat(3, 1fr); gap: 80px; } }
      .footer-logo { display: flex; align-items: center; gap: 12px; margin-bottom: 24px; }
      .footer-logo .jf { color: var(--orange); font-weight: 900; font-size: 24px; }
      .footer-logo .dev { color: var(--bone); font-weight: 700; font-size: 12px; letter-spacing: 0.2em; text-transform: uppercase; }
