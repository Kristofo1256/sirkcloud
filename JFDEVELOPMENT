<!doctype html>
<html lang="pl">
  <head>
    <meta charset="UTF-8" />
    <link rel="icon" type="image/svg+xml" href="/vite.svg" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>JF Development — Profesjonalna Firma Budowlana | Domy, Apartamenty, Bloki</title>
    <meta name="description" content="JF Development — profesjonalna firma budowlana z ponad 18-letnim doświadczeniem. Budujemy domy jednorodzinne, apartamenty i bloki mieszkalne. Ponad 120 zrealizowanych zleceń." />
    <meta property="og:title" content="JF Development — Budujemy Trwałość" />
    <meta property="og:description" content="Profesjonalna firma budowlana z ponad 18-letnim doświadczeniem. Ponad 120 zadowolonych klientów." />
